{
  "expo": {
    "name": "Trimswipe",
    "slug": "slim-storage",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trimswipe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.fiskerik.trimswipe",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Behövs för att skanna bilder.",
        "NSPhotoLibraryUsageDescription": "Behövs för att välja dina bilder.",
        "NSPhotoLibraryAddUsageDescription": "Behövs för att spara bilder."
      }
    },
    "plugins": [
      "expo-router",
      [
        "react-native-purchases",
        {
          "ios": {
            "usesStoreKit2JWS": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d4669864-8848-4389-9831-f565f1295982"
      }
    }
  }
}